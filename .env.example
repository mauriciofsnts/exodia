# --- Discord (required) ---
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=your_guild_id_for_dev  # optional: deploy slash commands to a single guild in dev

# --- Bot ---
PREFIX=!                                # default global prefix (overridable per-guild via !config prefix)
LOG_LEVEL=info                          # debug | info | warn | error

# --- Infra ---
REDIS_URL=redis://localhost:6379        # required: guild config, stats, cooldowns, external-response cache
DATABASE_URL=                           # optional: postgres://user:pass@host:5432/db — empty = run without persistence

# --- Notifications ---
ADMIN_USER_ID=                          # optional: Discord user ID that gets a DM on unexpected errors

# --- Music ---
PLAYER_IDLE_TIMEOUT_MS=300000           # optional: ms before leaving an empty voice channel (default 5min)
AUDIO_PROVIDER=ytdl                     # ytdl (default, direct YouTube — needs YTDL_COOKIE off a DC IP) | lavalink (more reliable in a datacenter)
YTDL_COOKIE=                            # ytdl only: logged-in YouTube cookies (JSON array or "k=v; k2=v2" header) — required to beat the bot-check from a datacenter
YTDL_PLAYER_CLIENTS=                    # ytdl only, optional: comma-separated InnerTube clients to try, e.g. WEB_EMBEDDED,TV
LAVALINK_HOST=localhost                 # Lavalink server host (in k8s: the Service name, e.g. lavalink)
LAVALINK_PORT=2333                      # Lavalink server port
LAVALINK_PASSWORD=youshallnotpass       # must match Lavalink's server.password
LAVALINK_SECURE=false                   # true if Lavalink is behind TLS (wss/https)

# --- External services ---
SHORTENER_ENDPOINT=                     # optional: GET shortener with a {url} placeholder (default: TinyURL), or the Shurl POST endpoint when SHORTENER_API_KEY is set
SHORTENER_API_KEY=                      # optional: when set, use the Shurl provider (JSON/POST) against SHORTENER_ENDPOINT
SPORTSDB_API_KEY=3                      # TheSportsDB key; public test key "3" works (real key unlocks upcoming fixtures)
