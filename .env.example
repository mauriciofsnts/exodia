DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=your_guild_id_for_dev  # optional: deploy to single guild in dev

PREFIX=!
LOG_LEVEL=info  # debug | info | warn | error

REDIS_URL=redis://localhost:6379

DATABASE_URL=  # optional: postgres://user:pass@host:5432/db — leave empty to run without persistence

ADMIN_USER_ID=  # optional: Discord user ID to receive DM on unexpected errors

PLAYER_IDLE_TIMEOUT_MS=300000  # optional: ms before leaving an empty voice channel (default 5min)
