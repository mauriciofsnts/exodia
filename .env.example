# --- Discord (required) ---
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=your_guild_id_for_dev  # optional: deploy slash commands to a single guild in dev

# --- Bot ---
PREFIX=!                                # default global prefix (overridable per-guild via !config prefix)
LOG_LEVEL=info                          # debug | info | warn | error

# --- Infra ---
REDIS_URL=redis://localhost:6379        # required: guild config, stats, cooldowns, external-response cache
DATABASE_URL=                           # optional: postgres://user:pass@host:5432/db — empty = run without persistence

# --- Notifications ---
ADMIN_USER_ID=                          # optional: Discord user ID that gets a DM on unexpected errors

# --- Music ---
PLAYER_IDLE_TIMEOUT_MS=300000           # optional: ms before leaving an empty voice channel (default 5min)

# --- External services ---
SHORTENER_ENDPOINT=                     # optional: GET shortener with a {url} placeholder (default: TinyURL)
SPORTSDB_API_KEY=3                      # TheSportsDB key; public test key "3" works (real key unlocks upcoming fixtures)
